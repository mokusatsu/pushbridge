{
  "name": "pushbridge-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node scripts/check-all.mjs",
    "worker:build": "esbuild infra/cloudflare/worker/src/index.ts --bundle --format=esm --platform=browser --target=es2022 --outfile=infra/cloudflare/worker/index.mjs --sourcemap=external --sources-content=false --legal-comments=none",
    "worker:typecheck": "tsc -p infra/cloudflare/worker/tsconfig.json --noEmit",
    "worker:test": "vitest run --config infra/cloudflare/worker/vitest.config.ts",
    "worker:check": "npm run worker:build && npm run worker:typecheck && npm run worker:test",
    "extension:build": "node apps/chromium-extension/build.mjs",
    "extension:typecheck": "tsc -p apps/chromium-extension/tsconfig.json --noEmit",
    "extension:test": "vitest run --config apps/chromium-extension/vitest.config.ts",
    "extension:e2e": "node scripts/chromium-extension-e2e.mjs",
    "extension:e2e:local": "node scripts/cloudflare-extension-e2e.mjs",
    "extension:e2e:remote": "node scripts/cloudflare-extension-e2e.mjs",
    "extension:check": "npm run extension:build && npm run extension:typecheck && npm run extension:test && npm run extension:e2e",
    "extension:package": "npm run extension:build && node apps/chromium-extension/package.mjs",
    "extension:store:evidence": "npm run extension:build && node scripts/chromium-extension-store-evidence.mjs",
    "cloudflare:state:diagnose": "node infra/cloudflare/scripts/diagnose-terraform-state.mjs",
    "cloudflare:wrangler:render": "node infra/cloudflare/scripts/render-wrangler-config.mjs",
    "cloudflare:web-push:generate": "node infra/cloudflare/scripts/generate-web-push-credentials.mjs",
    "cloudflare:web-push:render": "node infra/cloudflare/scripts/render-web-push-tfvars.mjs",
    "cloudflare:r2-direct:render": "node infra/cloudflare/scripts/render-r2-direct-tfvars.mjs",
    "cloudflare:local:migrate": "npx --yes wrangler@4 d1 migrations apply DB --local --config infra/cloudflare/wrangler.local.jsonc --persist-to .runtime/wrangler",
    "cloudflare:local:dev": "npx --yes wrangler@4 dev --local --config infra/cloudflare/wrangler.local.jsonc --persist-to .runtime/wrangler --ip 127.0.0.1 --port 8787",
    "cloudflare:local:smoke": "node scripts/cloudflare-local-smoke.mjs",
    "cloudflare:local:passkey-e2e": "node scripts/cloudflare-passkey-e2e.mjs",
    "cloudflare:local:recovery-drill": "node scripts/cloudflare-d1-recovery-drill.mjs",
    "cloudflare:remote:smoke": "node scripts/cloudflare-remote-smoke.mjs",
    "cloudflare:remote:web-push-e2e": "node scripts/cloudflare-web-push-e2e.mjs",
    "cloudflare:remote:cron-evidence": "node scripts/cloudflare-cron-evidence.mjs",
    "cloudflare:remote:metrics-evidence": "node scripts/cloudflare-metrics-evidence.mjs",
    "cloudflare:remote:load-evidence": "node scripts/cloudflare-load-evidence.mjs",
    "cloudflare:remote:monitor": "node scripts/cloudflare-synthetic-monitor.mjs",
    "cloudflare:remote:e2e": "npm run --prefix apps/web-pwa test:e2e:remote",
    "pwa:evidence": "npm run --prefix apps/web-pwa evidence:browser"
  },
  "engines": {
    "node": ">=22.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.7",
    "@cloudflare/workers-types": "^5.20260722.1",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.2",
    "@types/node": "^26.1.1",
    "esbuild": "^0.28.1",
    "fflate": "^0.8.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "@simplewebauthn/server": "13.3.2"
  }
}
