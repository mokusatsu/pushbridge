# Browser-visible defaults. The browser calls /api/v1; the local proxy removes
# the /api prefix before forwarding to RelayMock's /v1 routes.
VITE_API_BASE_URL=/api/v1
VITE_REALTIME_PATH=/realtime
VITE_AUTH_MODE=bearer
VITE_REMEMBER_BEARER_TOKEN=true
VITE_CURRENT_DEVICE_ID=
VITE_STORAGE_NAMESPACE=relaymock-local

# Used only until GET /v1/system/capabilities succeeds. RelayMock 0.1.1's
# recommended_poll_interval_seconds becomes authoritative after connection.
VITE_POLL_INTERVAL_SECONDS=30
VITE_AUTO_CACHE_RECEIVED_FILES=true
VITE_LOCAL_FILE_CACHE_MAX_BYTES=536870912

# Used only by Vite/local gateway on the developer machine.
API_PROXY_TARGET=http://127.0.0.1:8000
LOCAL_GATEWAY_HOST=127.0.0.1
LOCAL_GATEWAY_PORT=4173
