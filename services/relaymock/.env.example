RELAYMOCK_APP_VERSION=0.1.1
RELAYMOCK_ENVIRONMENT_ID=relaymock-local
RELAYMOCK_DATABASE_PATH=./data/relaymock.db
RELAYMOCK_STORAGE_DIR=./data/objects
RELAYMOCK_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
RELAYMOCK_MAX_FILE_SIZE_BYTES=26214400
RELAYMOCK_MAX_PUSH_PAYLOAD_BYTES=2000000
RELAYMOCK_MAX_DEVICES=10
RELAYMOCK_FILE_TTL_SECONDS=86400,604800,2592000
RELAYMOCK_DEFAULT_FILE_TTL_SECONDS=2592000
RELAYMOCK_FILE_ALIAS_TTL_SECONDS=15552000
RELAYMOCK_STORAGE_BUDGET_BYTES=8589934592
RELAYMOCK_STORAGE_HIGH_WATERMARK_PERCENT=95
RELAYMOCK_STORAGE_CLEANUP_TARGET_PERCENT=85
RELAYMOCK_DEFAULT_PUSH_TTL_SECONDS=2592000
RELAYMOCK_UPLOAD_TICKET_TTL_SECONDS=120
RELAYMOCK_DOWNLOAD_TICKET_TTL_SECONDS=60
RELAYMOCK_TICKET_RECORD_RETENTION_SECONDS=86400
RELAYMOCK_CLEANUP_INTERVAL_SECONDS=60
RELAYMOCK_RECOMMENDED_POLL_INTERVAL_SECONDS=30
# Development-only administration is disabled unless explicitly enabled.
RELAYMOCK_ENABLE_MOCK_ADMIN=false
RELAYMOCK_ADMIN_TOKEN=change-me
RELAYMOCK_WEB_PUSH_SUBSCRIPTION_REGISTRATION=true
RELAYMOCK_WEB_PUSH_DELIVERY=false
