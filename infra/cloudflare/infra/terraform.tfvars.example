# Do not put CLOUDFLARE_API_TOKEN here. Export it as an environment variable.
account_id   = "0123456789abcdef0123456789abcdef"
project_name = "pushbridge"
environment  = "dev"

# Temporary auth bootstrap. Enable only in an Access-protected dev stack.
enable_dev_bootstrap            = false
require_dev_bootstrap_turnstile = false
dev_bootstrap_rate_limit        = 20

# Passkeys stay disabled until an explicit RP hostname and exact HTTPS origin
# are selected. Do not copy workers.dev/custom hostnames here by assumption.
# passkey_rp_id              = "push.example.com"
# passkey_expected_origins   = ["https://push.example.com"]
passkey_rp_name             = "Pushbridge"
require_passkey_turnstile   = true
auth_rate_limit             = 20
account_auth_rate_limit     = 20
device_mutation_rate_limit  = 300
require_e2ee                = true

# Protect the complete hostname (Worker API and Static Assets) with Cloudflare
# Access. Use /32 for one IPv4 address. Set access_ip_allowlist = null to disable.
access_ip_allowlist = {
  hostname = "pushbridge-dev.<your-workers-subdomain>.workers.dev"
  cidrs = [
    "203.0.113.10/32",
    "2001:db8::1234/128",
  ]
}

# Optional automation access. Use the Service Token resource UUID, not its
# Client ID or Client Secret. Keep real IDs in an ignored *.auto.tfvars file.
access_service_token_ids = []

# Optional free-plan email delivery for Cloudflare incident and Access Service
# Token expiration notifications. Leave null until the operator destination is decided.
notification_email = null

# Dedicated least-privilege R2 S3 credentials. Never reuse the Terraform
# backend credentials. Generate an ignored r2-direct.auto.tfvars file.
r2_s3_access_key_id     = null
r2_s3_secret_access_key = null

# For a production custom domain:
# custom_domain = {
#   hostname = "push.example.com"
#   zone_id  = "0123456789abcdef0123456789abcdef"
# }
# enable_workers_dev = false
# additional_app_hostnames = ["push.example.com"]

# Supply this only for the first apply that creates UserHub, then remove it.
# Future Durable Object schema changes must use the current tag as old_tag and
# a new tag as new_tag for one apply only.
# durable_object_migration = {
#   new_tag            = "v1"
#   new_sqlite_classes = ["UserHub"]
# }

# When using only workers.dev, add the exact hostname once known:
# additional_app_hostnames = [
#   "pushbridge-dev.<your-workers-subdomain>.workers.dev",
#   "localhost"
# ]

# Queue delivery is intentionally off for the low-cost MVP.
enable_queue = false

# Operational application budget. Do not substitute provider contract limits.
storage_budget_bytes           = 8589934592
storage_pressure_high_percent  = 95
storage_cleanup_target_percent = 85
# storage_monthly_byte_day_budget = 257698037760

# Extra application configuration. These are not secrets.
worker_plain_text_vars = {
  MAX_FILE_BYTES = "26214400"
}

# Phase 3 Web Push. Keep the private/data keys only in ignored tfvars.
# vapid_public_key  = "<base64url 65-byte uncompressed P-256 public key>"
# vapid_private_key = "<base64url 32-byte P-256 private key>"
# vapid_subject     = "https://pushbridge-dev.<your-workers-subdomain>.workers.dev"
# web_push_data_key = "<base64url 32-byte AES data key>"

# Store values only in an uncommitted tfvars file or inject through CI.
# These values are written to Terraform state, which must be protected.
worker_secrets = {
  # SESSION_SIGNING_KEY = "replace-with-a-random-value"
  # VAPID_PRIVATE_KEY   = "replace-with-the-private-key"
}
