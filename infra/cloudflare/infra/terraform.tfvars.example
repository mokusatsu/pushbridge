# Do not put CLOUDFLARE_API_TOKEN here. Export it as an environment variable.
account_id   = "0123456789abcdef0123456789abcdef"
project_name = "pushbridge"
environment  = "dev"

# Protect the complete hostname (Worker API and Static Assets) with Cloudflare
# Access. Use /32 for one IPv4 address. Set access_ip_allowlist = null to disable.
access_ip_allowlist = {
  hostname = "pushbridge-dev.<your-workers-subdomain>.workers.dev"
  cidrs = [
    "203.0.113.10/32",
    "2001:db8::1234/128",
  ]
}

# For a production custom domain:
# custom_domain = {
#   hostname = "push.example.com"
#   zone_id  = "0123456789abcdef0123456789abcdef"
# }
# enable_workers_dev = false
# additional_app_hostnames = ["push.example.com"]

# Supply this only for the first apply that creates UserHub, then remove it.
# Future Durable Object schema changes must use the current tag as old_tag and
# a new tag as new_tag for one apply only.
# durable_object_migration = {
#   new_tag            = "v1"
#   new_sqlite_classes = ["UserHub"]
# }

# When using only workers.dev, add the exact hostname once known:
# additional_app_hostnames = [
#   "pushbridge-dev.<your-workers-subdomain>.workers.dev",
#   "localhost"
# ]

# Queue delivery is intentionally off for the low-cost MVP.
enable_queue = false

# Extra application configuration. These are not secrets.
worker_plain_text_vars = {
  MAX_FILE_BYTES = "26214400"
}

# Store values only in an uncommitted tfvars file or inject through CI.
# These values are written to Terraform state, which must be protected.
worker_secrets = {
  # SESSION_SIGNING_KEY = "replace-with-a-random-value"
  # VAPID_PRIVATE_KEY   = "replace-with-the-private-key"
}
