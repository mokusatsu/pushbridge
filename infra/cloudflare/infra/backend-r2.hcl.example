# Copy this example to the ignored backend-r2.hcl, then pass it with:
# terraform init -backend-config=backend-r2.hcl
# Export AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY for the dedicated R2 state token.
# The dev stack currently uses this bucket/key. Changing either selects a
# different state object; do not treat such a change as an in-place migration.
bucket = "pushbridge-terraform-state"
key    = "pushbridge/dev/terraform.tfstate"
region = "auto"

endpoints = {
  s3 = "https://<CLOUDFLARE_ACCOUNT_ID>.r2.cloudflarestorage.com"
}

skip_credentials_validation = true
skip_region_validation      = true
skip_requesting_account_id  = true
skip_metadata_api_check     = true
skip_s3_checksum            = true
use_path_style              = true
